# Database (SQLite для локального запуска без Docker, PostgreSQL для Docker)
DATABASE_URL=sqlite+aiosqlite:///./lessgame.db
# DATABASE_URL=postgresql+asyncpg://lessgame:lessgame@localhost:5432/lessgame

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# SMTP (Mailpit in dev: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lessgame.local

# Storage: local | s3
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# S3 / MinIO (when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lessgame
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/lessgame
